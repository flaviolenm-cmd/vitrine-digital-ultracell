{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "vitrine-digital-ultracell",
  "pages_build_output_dir": ".",
  "compatibility_date": "2026-04-21",
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "vitrine-ultracell-db",
      "database_id": "SUBSTITUA_PELO_DATABASE_ID_DO_D1"
    }
  ],
  "vars": {
    "PIX_KEY": "000.000.000-00",
    "APP_NAME": "Vitrine Digital / ULTRACELL Peças"
  }
}
